<?xml version="1.0" encoding="utf-8"?>
<!--
    PAGE 2 LAYOUT: Event Management Screen

    DATE & TIME use Button + TextView combos (like LAB8 Q1 AddTaskActivity):
    - User clicks the button → Picker dialog opens → selected value shows in TextView

    TO SWITCH BACK TO PLAIN EDITTEXT (if question doesn't want pickers):
    - Delete the LinearLayout containing btnPickDate/tvDate (or btnPickTime/tvTime)
    - Uncomment the plain EditText versions below them
    - In Java: use etDate.getText().toString() instead of selectedDate variable
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Page Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event Management"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Serial Number -->
    <EditText
        android:id="@+id/etSerialNo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Event Serial No (unique)"
        android:layout_marginBottom="10dp"/>

    <!-- Event Name -->
    <EditText
        android:id="@+id/etEventName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Event Name"
        android:layout_marginBottom="10dp"/>

    <!-- ═══ DATE PICKER (Button + TextView) ═══ -->
    <!-- Same pattern as LAB8 Q1: btnPickDate opens dialog, tvDate shows result -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btnPickDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pick Date"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No date selected"
            android:layout_marginStart="15dp"
            android:textSize="16sp"
            android:gravity="center_vertical"/>
    </LinearLayout>

    <!--
        ═══ PLAIN EDITTEXT VERSION (uncomment if question doesn't want picker) ═══
        <EditText
            android:id="@+id/etEventDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Event Date (e.g. 25/04/2026)"
            android:layout_marginBottom="10dp"/>
    -->

    <!-- ═══ TIME PICKER (Button + TextView) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/btnPickTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pick Time"/>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No time selected"
            android:layout_marginStart="15dp"
            android:textSize="16sp"
            android:gravity="center_vertical"/>
    </LinearLayout>

    <!--
        ═══ PLAIN EDITTEXT VERSION (uncomment if question doesn't want picker) ═══
        <EditText
            android:id="@+id/etEventTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Event Time (e.g. 10:00 AM)"
            android:layout_marginBottom="10dp"/>
    -->

    <!-- Event Location -->
    <EditText
        android:id="@+id/etEventLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Event Location"
        android:layout_marginBottom="20dp"/>

    <!-- Add Event Button -->
    <Button
        android:id="@+id/btnAddEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add New Event"
        android:layout_marginBottom="10dp"/>

    <!-- Update Event Button -->
    <Button
        android:id="@+id/btnUpdateEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Update Event (by Serial No)"
        android:layout_marginBottom="10dp"/>

    <!-- Navigate to Event Registration (Page 3) -->
    <Button
        android:id="@+id/btnGoToRegistration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Go to Event Registration →"/>

</LinearLayout>
